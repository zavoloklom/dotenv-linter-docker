{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  enabledManagers: [
    'dockerfile',
    'github-actions',
    'custom.regex',
  ],
  schedule: [
    'before 8am on monday',
  ],
  semanticCommits: 'enabled',
  prConcurrentLimit: 5,
  prHourlyLimit: 2,
  dependencyDashboard: false,
  configMigration: true,
  packageRules: [
    {
      matchUpdateTypes: [
        'patch',
      ],
      automerge: true,
    },
    {
      matchManagers: [
        'dockerfile',
      ],
      groupName: 'Docker base images',
      semanticCommitType: 'deps',
    },
    {
      matchManagers: [
        'github-actions',
      ],
      groupName: 'GitHub Actions',
      semanticCommitType: 'ci',
      semanticCommitScope: 'deps',
      pinDigests: true,
    },
    {
      matchManagers: [
        'custom.regex',
      ],
      groupName: 'Taskfile images',
      semanticCommitType: 'deps',
      semanticCommitScope: 'dev',
    },
  ],
  customManagers: [
    {
      // Tracks Docker images in Taskfile via `# renovate: docker` comments.
      // Renovate's Docker datasource parses the registry from depName automatically.
      //
      //   VAR_NAME: image:tag                         # renovate: docker  (Docker Hub, no org)
      //   VAR_NAME: org/image:tag                     # renovate: docker  (Docker Hub, with org)
      //   VAR_NAME: ghcr.io/owner/image:tag           # renovate: docker  (registry without port)
      //   VAR_NAME: registry.example.com:5050/image:tag  # renovate: docker  (registry with port)
      //
      // Pattern 1 — Docker Hub: first segment has no dots (no registry hostname).
      // Pattern 2 — Registry without port: hostname has a dot, followed by / directly.
      // Pattern 3 — Registry with port: hostname:port/ prefix before the image path.
      customType: 'regex',
      managerFilePatterns: [
        '/(^|/)[Tt]askfile\.ya?ml$/',
      ],
      matchStrings: [
        '(?:^|\\r\\n|\\r|\\n)\\s*[A-Z0-9_]+:\\s+(?<depName>[a-z0-9][a-z0-9-]*(?:/[a-z0-9][a-z0-9._-]*)*):(?<currentValue>[^\\s#\\n/]+)\\s+#\\s+renovate:\\s+docker',
        '(?:^|\\r\\n|\\r|\\n)\\s*[A-Z0-9_]+:\\s+(?<depName>[a-z0-9][a-z0-9.-]*\\.[a-z0-9.-]+/[a-z0-9][a-z0-9._/-]*):(?<currentValue>[^\\s#\\n/]+)\\s+#\\s+renovate:\\s+docker',
        '(?:^|\\r\\n|\\r|\\n)\\s*[A-Z0-9_]+:\\s+(?<depName>[a-z0-9][a-z0-9.-]+:\\d+/[a-z0-9][a-z0-9._/-]*):(?<currentValue>[^\\s#\\n/]+)\\s+#\\s+renovate:\\s+docker'
      ],
      datasourceTemplate: 'docker',
    },
  ],
}
