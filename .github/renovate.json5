{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  enabledManagers: [
    'dockerfile',
    'github-actions',
    'custom.regex',
  ],
  schedule: [
    'before 8am on monday',
  ],
  semanticCommits: 'enabled',
  prConcurrentLimit: 5,
  prHourlyLimit: 2,
  packageRules: [
    {
      matchUpdateTypes: [
        'patch',
      ],
      automerge: true,
    },
    {
      matchManagers: [
        'dockerfile',
      ],
      groupName: 'Docker base images',
      semanticCommitType: 'deps',
    },
    {
      matchManagers: [
        'github-actions',
      ],
      groupName: 'GitHub Actions',
      semanticCommitType: 'ci',
      semanticCommitScope: 'deps',
      pinDigests: true,
    },
    {
      matchManagers: [
        'custom.regex',
      ],
      groupName: 'Taskfile images',
      semanticCommitType: 'deps',
      semanticCommitScope: 'dev',
    },
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '^Taskfile\\.yml$',
      ],
      matchStrings: [
        '(?:^|\\r\\n|\\r|\\n)\\s*[A-Z0-9_]+:\\s+(?<depName>[a-z0-9][a-z0-9-]*(?:/[a-z0-9][a-z0-9._-]*)*):(?<currentValue>[^\\s#\\n/]+)\\s+#\\s+renovate:\\s+docker',
      ],
      datasourceTemplate: 'docker',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '^Taskfile\\.yml$',
      ],
      matchStrings: [
        '(?:^|\\r\\n|\\r|\\n)\\s*[A-Z0-9_]+:\\s+(?<depName>[a-z0-9][a-z0-9.-]*\\.[a-z0-9.-]+/[a-z0-9][a-z0-9._/-]*):(?<currentValue>[^\\s#\\n/]+)\\s+#\\s+renovate:\\s+docker',
      ],
      datasourceTemplate: 'docker',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '^Taskfile\\.yml$',
      ],
      matchStrings: [
        '(?:^|\\r\\n|\\r|\\n)\\s*[A-Z0-9_]+:\\s+(?<registryUrl>[a-z0-9][a-z0-9.-]+:\\d+)/(?<depName>[a-z0-9][a-z0-9._/-]*):(?<currentValue>[^\\s#\\n/]+)\\s+#\\s+renovate:\\s+docker',
      ],
      datasourceTemplate: 'docker',
      registryUrlTemplate: 'https://{{{registryUrl}}}',
    },
  ],
}
